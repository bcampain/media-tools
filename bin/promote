#!/usr/bin/env bash
set -Eeuo pipefail

ERR_TRAP_FIRED="0"

log_line() {
  local logfile="$1"; shift
  printf "%s\n" "$*" >> "$logfile"
}

notify_failure() {
  # args: title, message
  local title="$1"
  local msg="$2"

  # Make a one-line version for the logfile:
  # turn literal '\n' sequences into ' | '
  local msg_one_line="${msg//\\n/ | }"

  if [[ -n "${LOGFILE:-}" && -f "${LOGFILE:-}" ]]; then
    log_line "$LOGFILE" "$title"
    log_line "$LOGFILE" "$msg_one_line"
  fi

  # Discord: keep the original msg with newlines
  if command -v notify_discord >/dev/null 2>&1; then
    notify_discord "$title" "$(printf '%b' "$msg")" "${LOGFILE:-}" || true
  fi
}

on_err() {
  local rc=$?
  local line="${1:-unknown}"
  local cmd="${2:-unknown}"

  ERR_TRAP_FIRED="1"

  # Always print to console
  echo "ERROR: crashed (rc=$rc) at line $line: $cmd" >&2

  notify_failure \
    "❌ exception: promote" \
    "${TARGET_LABEL:-Target}: ${LABEL_VALUE:-unknown} | run_id=${RUN_ID:-unknown}\nrc=$rc | line=$line\ncmd: $cmd"

  exit "$rc"
}

on_exit() {
  local rc=$?

  # If ERR trap already handled it, don't double-notify here.
  [[ "$ERR_TRAP_FIRED" == "1" ]] && return 0

  # Only catch validation exits (explicit exit 2)
  [[ "$rc" == "2" ]] || return 0

  notify_failure \
    "⚠️ validation failed: promote" \
    "${TARGET_LABEL:-Target}: ${LABEL_VALUE:-unknown} | run_id=${RUN_ID:-unknown}\nExited with rc=2 (validation)."
}

die2() {  # validation failure
  local reason="$1"
  echo "VALIDATION: $reason" >&2
  if [[ -n "${LOGFILE:-}" && -f "${LOGFILE:-}" ]]; then
    log_line "$LOGFILE" "VALIDATION: $reason"
  fi
  exit 2
}

trap 'on_err "$LINENO" "$BASH_COMMAND"' ERR
trap 'on_exit' EXIT

RETENTION_DAYS="30"
DRY_RUN="0"
OVERWRITE="0"
RUN_ID=""

usage() {
  echo "Usage:"
  echo "  promote <target> [--run-id MMDDYYHHmmss] [--retention-days N] [--dry-run] [--overwrite]"
  echo "  Note: overwrite is now the default behavior when a library file exists."
  echo ""
  echo "Targets:"
  echo "  TV (show root only):"
  echo "    /staging/tv/<Show Name>"
  echo "  Movies/Clips (dir or single file):"
  echo "    /staging/movies[/subdir]"
  echo "    /staging/movies/path/to/file.mp4"
  echo "    /staging/clips[/subdir]"
  echo "    /staging/clips/path/to/file.mp4"
  exit 1
}

timestamp_now() { date "+%Y-%m-%d %H:%M:%S %z"; }
run_id_now() { date "+%m%d%y%H%M%S"; }

pick_newest_log() {
  local prefix="$1"
  ls -1t /logs/${prefix}-media-tools-????????????.log 2>/dev/null | head -n 1 || true
}

resolve_promote_target() {
  # sets:
  #   KIND=tv|movies|clips
  #   STAGE_BASE=/staging/<kind>
  #   IN_BASE=/incoming/<kind>
  #   LIB_BASE=/library/<kind>
  #   TARGET_MODE=dir|file
  #   TARGET_PATH=(normalized)
  local p="$1"

  if [[ ! "$p" =~ ^/staging/ ]]; then
    die2 "Target must be under /staging. Got: $p"
  fi

  if [[ "$p" == /staging/tv/* ]]; then
    KIND="tv"
    STAGE_BASE="/staging/tv"
    IN_BASE="/incoming/tv"
    LIB_BASE="/library/tv"

    [[ -d "$p" ]] || die2 "TV target must be a directory show root: /staging/tv/<Show Name>"
    [[ "$p" =~ ^/staging/tv/[^/]+$ ]] || die2 "TV target must be show root only: /staging/tv/<Show Name>"

    TARGET_MODE="dir"
    TARGET_PATH="$p"
    return 0
  fi

  if [[ "$p" == /staging/movies* ]]; then
    KIND="movies"
    STAGE_BASE="/staging/movies"
    IN_BASE="/incoming/movies"
    LIB_BASE="/library/movies"
  elif [[ "$p" == /staging/clips* ]]; then
    KIND="clips"
    STAGE_BASE="/staging/clips"
    IN_BASE="/incoming/clips"
    LIB_BASE="/library/clips"
  else
    die2 "Target must live under /staging/tv, /staging/movies, or /staging/clips. Got: $p"
  fi

  if [[ -d "$p" ]]; then
    TARGET_MODE="dir"
    TARGET_PATH="$p"
  elif [[ -f "$p" && "$p" =~ \.mp4$ ]]; then
    TARGET_MODE="file"
    TARGET_PATH="$p"
  else
    die2 "Target must be a directory or a single .mp4 file. Got: $p"
  fi
}

find_incoming_original() {
  # movies/clips only:
  # rel_mp4 is relative to STAGE_BASE, e.g. Foo/Alien.mp4
  local rel_mp4="$1"
  local rel_dir base stem dir ext

  rel_dir="$(dirname "$rel_mp4")"
  base="$(basename "$rel_mp4")"
  stem="${base%.mp4}"
  if [[ "$rel_dir" == "." ]]; then
    dir="$IN_BASE"
  else
    dir="$IN_BASE/$rel_dir"
  fi

  for ext in mkv mp4 m4v; do
    if [[ -f "$dir/$stem.$ext" ]]; then
      printf "%s\n" "$dir/$stem.$ext"
      return 0
    fi
  done

  return 1
}

if [[ $# -lt 1 ]]; then usage; fi
TARGET="$1"; shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    --run-id) RUN_ID="${2:-}"; shift 2 ;;
    --retention-days) RETENTION_DAYS="${2:-}"; shift 2 ;;
    --dry-run) DRY_RUN="1"; shift ;;
    --overwrite) OVERWRITE="1"; shift ;;
    -h|--help) usage ;;
    *) echo "Unknown arg: $1"; usage ;;
  esac
done

resolve_promote_target "$TARGET"

SHOW_ROOT=""
SHOW_NAME=""
LIB_ROOT=""
INC_ROOT=""
ARCH_BASE=""
ARCH_DIR=""
TARGET_LABEL=""
LABEL_VALUE=""

if [[ "$KIND" == "tv" ]]; then
  SHOW_ROOT="$TARGET_PATH"
  SHOW_NAME="$(basename "$SHOW_ROOT")"
  LIB_ROOT="$LIB_BASE/$SHOW_NAME"
  INC_ROOT="$IN_BASE/$SHOW_NAME"
  ARCH_BASE="/staging/archive/tv/$SHOW_NAME"
  TARGET_LABEL="Show"
  LABEL_VALUE="$SHOW_NAME"
else
  # movies/clips
  LIB_ROOT="$LIB_BASE"
  INC_ROOT="$IN_BASE"
  ARCH_BASE="/staging/archive/$KIND"
  TARGET_LABEL="Kind"
  LABEL_VALUE="$KIND"
fi

if [[ "$DRY_RUN" == "0" ]]; then
  mkdir -p "$LIB_ROOT"
fi

# Decide log file
if [[ -n "$RUN_ID" ]]; then
  LOGFILE="/logs/${LABEL_VALUE}-media-tools-${RUN_ID}.log"
else
  LOGFILE="$(pick_newest_log "$LABEL_VALUE")"
  if [[ -n "$LOGFILE" ]]; then
    RUN_ID="$(sed -n 's/.*-media-tools-\([0-9]\{12\}\)\.log/\1/p' <<<"$(basename "$LOGFILE")" | head -n 1)"
  else
    RUN_ID="$(run_id_now)"
    LOGFILE="/logs/${LABEL_VALUE}-media-tools-${RUN_ID}.log"
  fi
fi

START_TS="$(timestamp_now)"
if [[ "$KIND" == "tv" ]]; then
  MSG="$(printf "Show: %s | run_id=%s" "$SHOW_NAME" "$RUN_ID")"
else
  MSG="$(printf "Kind: %s | run_id=%s\nTarget: %s" "$KIND" "$RUN_ID" "$TARGET_PATH")"
fi
command -v notify_discord >/dev/null 2>&1 && \
  notify_discord "📚 Step 3 of 3: Promote to Library started" "$MSG" || true

log_line "$LOGFILE" "${START_TS}  promote START"
log_line "$LOGFILE" "  run_id=${RUN_ID}"
log_line "$LOGFILE" "  staging=${TARGET_PATH}"
log_line "$LOGFILE" "  library=${LIB_ROOT}"
log_line "$LOGFILE" "  incoming=${INC_ROOT}"
log_line "$LOGFILE" "  archive_base=${ARCH_BASE}"
log_line "$LOGFILE" "  retention_days=${RETENTION_DAYS}"
log_line "$LOGFILE" "  overwrite=${OVERWRITE}"
log_line "$LOGFILE" "  kind=${KIND}"
log_line "$LOGFILE" "  files:"

# Fail if any .norm still present for directory targets (ignore macOS AppleDouble sidecars like ._*)
if [[ "$TARGET_MODE" == "dir" ]]; then
  if find "$TARGET_PATH" -type f -name "*.norm.mp4" ! -name "._*" -print -quit | grep -q .; then
    echo "ERROR: .norm.mp4 files remain under target. Run normalize_audio first." >&2
    if [[ "$KIND" == "tv" ]]; then
      MSG="$(printf "Show: %s | run_id=%s\n.norm.mp4 files remain under staging show root. Run normalize_audio first." "$SHOW_NAME" "$RUN_ID")"
    else
      MSG="$(printf "Kind: %s | run_id=%s\n.norm.mp4 files remain under target. Run normalize_audio first.\nTarget: %s" "$KIND" "$RUN_ID" "$TARGET_PATH")"
    fi
    command -v notify_discord >/dev/null 2>&1 && \
      notify_discord "⚠️ Step 3 of 3: Promote to Library finished" "$MSG" "$LOGFILE" || true
    exit 3
  fi
else
  # single-file target: refuse promoting .norm.mp4 explicitly
  if [[ "$TARGET_PATH" =~ \.norm\.mp4$ ]]; then
    die2 "Refusing to promote a .norm.mp4 file. Normalize first (expects final .mp4). Got: $TARGET_PATH"
  fi
fi

FILES=()
if [[ "$TARGET_MODE" == "file" ]]; then
  FILES=("$TARGET_PATH")
else
  mapfile -d '' FILES < <(
    find "$TARGET_PATH" -type f -name "*.mp4" ! -name "._*" ! -name "*.norm.mp4" ! -name "*.tmp" ! -name "*.tmp.mp4" -print0 | sort -z
  )
fi

if [[ ${#FILES[@]} -eq 0 ]]; then
  log_line "$LOGFILE" "    (none found)"
  log_line "$LOGFILE" "promote END status=OK"
  if [[ "$KIND" == "tv" ]]; then
    MSG="$(printf "Show: %s | run_id=%s\nNo final mp4 files found to promote. Nothing to do." "$SHOW_NAME" "$RUN_ID")"
  else
    MSG="$(printf "Kind: %s | run_id=%s\nNo final mp4 files found to promote. Nothing to do.\nTarget: %s" "$KIND" "$RUN_ID" "$TARGET_PATH")"
  fi
  command -v notify_discord >/dev/null 2>&1 && \
    notify_discord "⚠️ Step 3 of 3: Promote to Library finished" "$MSG" "$LOGFILE" || true
  exit 0
fi

FAILS=0
CREATED=0
OVERWRITTEN=0

# Track which staging files are safe to delete after success
declare -a DELETE_LATER=()

for src in "${FILES[@]}"; do
  if [[ "$KIND" == "tv" ]]; then
    rel="${src#$SHOW_ROOT/}"
    dest="$LIB_ROOT/$rel"
  else
    # movies/clips: relative to STAGE_BASE
    rel="${src#$STAGE_BASE/}"
    rel="${rel#/}"
    dest="$LIB_ROOT/$rel"
  fi

  dest_dir="$(dirname "$dest")"
  mkdir -p "$dest_dir"

  # If destination exists, we now overwrite by default.
  dest_existed="0"
  if [[ -f "$dest" ]]; then
    dest_existed="1"
  fi

  if [[ "$DRY_RUN" == "1" ]]; then
    if [[ "$dest_existed" == "1" ]]; then
      log_line "$LOGFILE" "    DRYRUN(overwrite): $rel -> ${dest#/library/}"
    else
      log_line "$LOGFILE" "    DRYRUN: $rel -> ${dest#/library/}"
    fi
    continue
  fi

  tmp="${dest}.tmp.$$"
  if rsync -a --inplace --partial --no-perms --no-owner --no-group --protect-args -- "$src" "$tmp"; then
    mv -f "$tmp" "$dest"
    if [[ "$dest_existed" == "1" ]]; then
      log_line "$LOGFILE" "    OVERWROTE: $rel"
      OVERWRITTEN=$((OVERWRITTEN+1))

      if [[ "$KIND" == "tv" ]]; then
        MSG="$(printf "Show: %s | run_id=%s\nOverwrote: %s" "$SHOW_NAME" "$RUN_ID" "${dest#/library/}")"
      else
        MSG="$(printf "Kind: %s | run_id=%s\nOverwrote: %s" "$KIND" "$RUN_ID" "${dest#/library/}")"
      fi

      command -v notify_discord >/dev/null 2>&1 && \
        notify_discord "♻️ Promote: Overwrote existing library file" "$MSG" "$LOGFILE" || true
    else
      log_line "$LOGFILE" "    CREATED: $rel"
      CREATED=$((CREATED+1))
    fi

    DELETE_LATER+=("$src")
  else
    rm -f "$tmp" || true
    log_line "$LOGFILE" "    FAILED(copy): $rel"
    FAILS=$((FAILS+1))
  fi
done

if [[ "$FAILS" -gt 0 ]]; then
  log_line "$LOGFILE" "promote END status=FAIL created=${CREATED} overwritten=${OVERWRITTEN} failed=${FAILS}"

  if [[ "$KIND" == "tv" ]]; then
    MSG="$(printf "Show: %s | run_id=%s\nPromote failed for %d files.\nCreated: %d, Overwritten: %d, Failed: %d" \
      "$SHOW_NAME" "$RUN_ID" "$FAILS" "$CREATED" "$OVERWRITTEN" "$FAILS")"
  else
    MSG="$(printf "Kind: %s | run_id=%s\nPromote failed for %d files.\nCreated: %d, Overwritten: %d, Failed: %d" \
      "$KIND" "$RUN_ID" "$FAILS" "$CREATED" "$OVERWRITTEN" "$FAILS")"
  fi

  command -v notify_discord >/dev/null 2>&1 && \
    notify_discord "❌ Step 3 of 3: Promote to Library finished with errors" "$MSG" "$LOGFILE" || true
  exit 4
fi

# Archive originals only after successful promote
if [[ "$DRY_RUN" == "0" ]]; then
  if [[ -d "$INC_ROOT" ]]; then
    ARCH_DIR="$ARCH_BASE/_archived-${RUN_ID}"
    mkdir -p "$ARCH_DIR"

    if [[ "$KIND" == "tv" ]]; then
      # Archive whole incoming show folder, archive all logs, then delete incoming show folder
      if rsync -a --inplace --partial -rlt --no-perms --no-owner --no-group --protect-args -- "$INC_ROOT/" "$ARCH_DIR/"; then
        log_line "$LOGFILE" "  archive: OK -> ${ARCH_DIR#/staging/}"

        rm -rf "$INC_ROOT"
      else
        log_line "$LOGFILE" "  archive: FAILED"
        exit 5
      fi
    else
      # movies/clips: archive + delete per-file originals (safe; never rm -rf incoming base)
      for staged in "${DELETE_LATER[@]}"; do
        rel_mp4="${staged#$STAGE_BASE/}"
        rel_mp4="${rel_mp4#/}"

        if orig="$(find_incoming_original "$rel_mp4")"; then
          rel_orig="${orig#$IN_BASE/}"
          rel_orig="${rel_orig#/}"
          orig_rel_dir="$(dirname "$rel_orig")"
          if [[ "$orig_rel_dir" == "." ]]; then
            dest_dir="$ARCH_DIR"
          else
            dest_dir="$ARCH_DIR/$orig_rel_dir"
          fi
          mkdir -p "$dest_dir"

          if rsync -a --inplace --partial -rlt --no-perms --no-owner --no-group --protect-args -- "$orig" "$dest_dir/"; then
            rm -f "$orig" || true
            log_line "$LOGFILE" "  archive: OK original -> ${dest_dir#/staging/}/$(basename "$orig")"
          else
            log_line "$LOGFILE" "  archive: FAILED original=$orig"
            exit 5
          fi
        else
          log_line "$LOGFILE" "  archive: WARN no incoming original found for staged_rel=$rel_mp4"
        fi
      done

      # clean empty dirs under incoming base (mindepth 1 preserves the base landing zone)
      find "$IN_BASE" -mindepth 1 -type d -empty -delete 2>/dev/null || true

      log_line "$LOGFILE" "  archive: OK -> ${ARCH_DIR#/staging/}"
    fi
  else
    log_line "$LOGFILE" "  archive: SKIPPED (incoming folder not found)"
  fi
else
  log_line "$LOGFILE" "  archive: DRYRUN"
fi

# Prune archives older than retention days (per target archive base)
if [[ "$DRY_RUN" == "0" ]]; then
  if [[ -d "$ARCH_BASE" ]]; then
    pruned=0
    while IFS= read -r -d '' d; do
      rm -rf "$d"
      pruned=$((pruned+1))
    done < <(find "$ARCH_BASE" -mindepth 1 -maxdepth 1 -type d -name "_archived-*" -mtime +"$RETENTION_DAYS" -print0)
    log_line "$LOGFILE" "  archive_prune: removed=${pruned} older_than_days=${RETENTION_DAYS}"
    if [[ "$pruned" -gt 0 ]]; then
      if [[ "$KIND" == "tv" ]]; then
        MSG="$(printf "Show: %s | run_id=%s\nPruned %d archives older than %d days." "$SHOW_NAME" "$RUN_ID" "$pruned" "$RETENTION_DAYS")"
      else
        MSG="$(printf "Kind: %s | run_id=%s\nPruned %d archives older than %d days." "$KIND" "$RUN_ID" "$pruned" "$RETENTION_DAYS")"
      fi
      command -v notify_discord >/dev/null 2>&1 && \
        notify_discord "⚠️ Step 3 of 3: Promote to Library archive prune" "$MSG" "$LOGFILE" || true
    fi
  else
    log_line "$LOGFILE" "  archive_prune: none (no archive dir)"
  fi
else
  log_line "$LOGFILE" "  archive_prune: DRYRUN older_than_days=${RETENTION_DAYS}"
fi

# Delete staging finals now that library is populated
if [[ "$DRY_RUN" == "0" ]]; then
  del=0
  for f in "${DELETE_LATER[@]}"; do
    rm -f "$f" && ((del++)) || true
  done

  if [[ "$KIND" == "tv" ]]; then
    # Remove empty dirs; show root may be removed too
    find "$SHOW_ROOT" -type d -empty -delete || true
    log_line "$LOGFILE" "  staging_cleanup: deleted_files=${del} (final mp4s)"
    log_line "$LOGFILE" "  staging_cleanup: removing_show_root=${SHOW_ROOT}"
  else
    # movies/clips: clean empty dirs under the TARGET_PATH but do not delete STAGE_BASE itself
    if [[ "$TARGET_MODE" == "dir" ]]; then
      # mindepth 1 prevents deleting the target dir itself
      find "$TARGET_PATH" -mindepth 1 -type d -empty -delete 2>/dev/null || true
    else
      find "$(dirname "$TARGET_PATH")" -mindepth 1 -type d -empty -delete 2>/dev/null || true
    fi
    log_line "$LOGFILE" "  staging_cleanup: deleted_files=${del} (final mp4s)"
  fi
else
  log_line "$LOGFILE" "  staging_cleanup: DRYRUN"
fi

END_TS="$(timestamp_now)"
log_line "$LOGFILE" "${END_TS}  promote END status=OK created=${CREATED} overwritten=${OVERWRITTEN} failed=0"

if [[ "$KIND" == "tv" ]]; then
  MSG="$(printf "Show: %s | run_id=%s | created=%s overwritten=%s failed=0" "$SHOW_NAME" "$RUN_ID" "$CREATED" "$OVERWRITTEN")"
else
  MSG="$(printf "Kind: %s | run_id=%s | created=%s overwritten=%s failed=0" "$KIND" "$RUN_ID" "$CREATED" "$OVERWRITTEN")"
fi
command -v notify_discord >/dev/null 2>&1 && \
  notify_discord "✅ Step 3 of 3: Promote to Library finished" "$MSG" "$LOGFILE" || true

# Remove staging scaffolding after successful promote
if [[ "$DRY_RUN" == "0" ]]; then
  if [[ "$KIND" == "tv" ]]; then
    rm -rf "$SHOW_ROOT"
  fi
fi

exit 0