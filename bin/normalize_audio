#!/usr/bin/env bash
set -Eeuo pipefail

ERR_TRAP_FIRED="0"

log_line() {
  local logfile="$1"; shift
  printf "%s\n" "$*" >> "$logfile"
}

notify_failure() {
  # args: title, message
  local title="$1"
  local msg="$2"

  # Make a one-line version for the logfile:
  # turn literal '\n' sequences into ' | '
  local msg_one_line="${msg//\\n/ | }"

  if [[ -n "${LOGFILE:-}" && -f "${LOGFILE:-}" ]]; then
    log_line "$LOGFILE" "$title"
    log_line "$LOGFILE" "$msg_one_line"
  fi

  # Discord: keep the original msg with newlines
  if command -v notify_discord >/dev/null 2>&1; then
    notify_discord "$title" "$(printf '%b' "$msg")" "${LOGFILE:-}" || true
  fi
}

on_err() {
  local rc=$?
  local line="${1:-unknown}"
  local cmd="${2:-unknown}"

  ERR_TRAP_FIRED="1"

  # Always print to console
  echo "ERROR: crashed (rc=$rc) at line $line: $cmd" >&2

  notify_failure \
    "❌ exception: normalize_audio" \
    "${TARGET_LABEL:-Target}: ${LABEL_VALUE:-unknown} | run_id=${RUN_ID:-unknown}\nrc=$rc | line=$line\ncmd: $cmd"

  exit "$rc"
}

on_exit() {
  local rc=$?

  # If ERR trap already handled it, don't double-notify here.
  [[ "$ERR_TRAP_FIRED" == "1" ]] && return 0

  # Only catch validation exits (explicit exit 2)
  [[ "$rc" == "2" ]] || return 0

  notify_failure \
    "⚠️ validation failed: normalize_audio" \
    "${TARGET_LABEL:-Target}: ${LABEL_VALUE:-unknown} | run_id=${RUN_ID:-unknown}\nExited with rc=2 (validation)."
}

die2() {  # validation failure
  local reason="$1"
  echo "VALIDATION: $reason" >&2
  if [[ -n "${LOGFILE:-}" && -f "${LOGFILE:-}" ]]; then
    log_line "$LOGFILE" "VALIDATION: $reason"
  fi
  exit 2
}

trap 'on_err "$LINENO" "$BASH_COMMAND"' ERR
trap 'on_exit' EXIT

# Defaults
TARGET_I="-16"
TRUE_PEAK="-1.5"
LRA="11"
STEREO_TRACK="on"
ONE_PASS="0"
DRY_RUN="0"
FORCE="0"
RUN_ID=""

usage() {
  echo "Usage:"
  echo "  normalize_audio <target> [--run-id MMDDYYHHmmss] [--target-i -16] [--true-peak -1.5] [--lra 11] [--stereo-track on|off] [--one-pass] [--dry-run] [--force]"
  echo ""
  echo "Targets:"
  echo "  TV (show root only):"
  echo "    /staging/tv/<Show Name>"
  echo "  Movies/Clips (dir or single file):"
  echo "    /staging/movies[/subdir]"
  echo "    /staging/movies/path/to/file.norm.mp4"
  echo "    /staging/clips[/subdir]"
  echo "    /staging/clips/path/to/file.norm.mp4"
  exit 1
}

timestamp_now() { date "+%Y-%m-%d %H:%M:%S %z"; }
run_id_now() { date "+%m%d%y%H%M%S"; }

pick_newest_log() {
  local prefix="$1"
  ls -1t /logs/${prefix}-media-tools-????????????.log 2>/dev/null | head -n 1 || true
}

ffprobe_channels() {
  ffprobe -v error -select_streams a:0 -show_entries stream=channels -of default=nw=1:nk=1 "$1" || echo ""
}

extract_loudnorm_json() {
  # Reads ffmpeg stderr/stdout and extracts the JSON object from loudnorm print_format=json
  # Outputs a single JSON object on stdout.
  awk '
    BEGIN{found=0; depth=0}
    /^{/ {if(found==0){found=1} }
    {
      if(found==1){
        print $0
        for(i=1;i<=length($0);i++){
          c=substr($0,i,1)
          if(c=="{") depth++
          if(c=="}") depth--
        }
        if(depth==0 && found==1){ exit }
      }
    }
  '
}

measure_loudnorm() {
  local in_file="$1"
  local filter="$2"

  filter="${filter%,}"  # strip one trailing comma if present

  local af="loudnorm=I=${TARGET_I}:TP=${TRUE_PEAK}:LRA=${LRA}:print_format=json"
  if [[ -n "$filter" ]]; then
    af="${filter},${af}"
  fi

  # Run ffmpeg, mirror all output to console, then extract JSON from the captured text.
  local out
  out="$(ffmpeg -hide_banner -i "$in_file" \
    -map 0:a:0 -vn -sn -dn \
    -af "$af" \
    -f null - 2>&1 | tee /dev/stderr)"

  printf '%s\n' "$out" | extract_loudnorm_json
}

apply_two_pass_filter() {
  local measured_json="$1"
  # Outputs loudnorm args for pass 2
  local mi mt ml mth off
  mi="$(jq -r '.input_i' <<<"$measured_json")"
  mt="$(jq -r '.input_tp' <<<"$measured_json")"
  ml="$(jq -r '.input_lra' <<<"$measured_json")"
  mth="$(jq -r '.input_thresh' <<<"$measured_json")"
  off="$(jq -r '.target_offset' <<<"$measured_json")"

  printf "loudnorm=I=%s:TP=%s:LRA=%s:measured_I=%s:measured_TP=%s:measured_LRA=%s:measured_thresh=%s:offset=%s:linear=true:print_format=summary" \
    "$TARGET_I" "$TRUE_PEAK" "$LRA" "$mi" "$mt" "$ml" "$mth" "$off"
}

resolve_staging_target() {
  # sets:
  #   KIND=tv|movies|clips
  #   STAGE_BASE=/staging/<kind>
  #   TARGET_MODE=dir|file
  #   TARGET_PATH=(normalized)
  local p="$1"

  [[ -e "$p" ]] || die2 "Target not found: $p"

  if [[ "$p" == /staging/tv/* ]]; then
    KIND="tv"
    STAGE_BASE="/staging/tv"
    [[ -d "$p" ]] || die2 "TV target must be a directory show root: /staging/tv/<Show Name>"
    [[ "$p" =~ ^/staging/tv/[^/]+$ ]] || die2 "TV target must be show root only: /staging/tv/<Show Name>"
    TARGET_MODE="dir"
    TARGET_PATH="$p"
    return 0
  fi

  if [[ "$p" == /staging/movies* ]]; then
    KIND="movies"
    STAGE_BASE="/staging/movies"
  elif [[ "$p" == /staging/clips* ]]; then
    KIND="clips"
    STAGE_BASE="/staging/clips"
  else
    die2 "Target must live under /staging/tv, /staging/movies, or /staging/clips. Got: $p"
  fi

  if [[ -d "$p" ]]; then
    TARGET_MODE="dir"
    TARGET_PATH="$p"
  elif [[ -f "$p" && "$p" =~ \.norm\.mp4$ ]]; then
    TARGET_MODE="file"
    TARGET_PATH="$p"
  else
    die2 "Target must be a directory or a single .norm.mp4 file. Got: $p"
  fi
}

# Parse args
if [[ $# -lt 1 ]]; then usage; fi
TARGET="$1"; shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    --run-id) RUN_ID="${2:-}"; shift 2 ;;
    --target-i) TARGET_I="${2:-}"; shift 2 ;;
    --true-peak) TRUE_PEAK="${2:-}"; shift 2 ;;
    --lra) LRA="${2:-}"; shift 2 ;;
    --stereo-track) STEREO_TRACK="${2:-}"; shift 2 ;;
    --one-pass) ONE_PASS="1"; shift ;;
    --dry-run) DRY_RUN="1"; shift ;;
    --force) FORCE="1"; shift ;;
    -h|--help) usage ;;
    *) echo "Unknown arg: $1"; usage ;;
  esac
done

resolve_staging_target "$TARGET"

SHOW_NAME=""
SHOW_ROOT=""
TARGET_LABEL=""
LABEL_VALUE=""
REL_BASE=""

RUN_ID="${RUN_ID:-}"

if [[ "$KIND" == "tv" ]]; then
  SHOW_ROOT="$TARGET_PATH"
  SHOW_NAME="$(basename "$SHOW_ROOT")"
  TARGET_LABEL="Show"
  LABEL_VALUE="$SHOW_NAME"
  REL_BASE="$SHOW_ROOT"
else
  TARGET_LABEL="Kind"
  LABEL_VALUE="$KIND"
  REL_BASE="$STAGE_BASE"
fi

if [[ -n "$RUN_ID" ]]; then
  LOGFILE="/logs/${LABEL_VALUE}-media-tools-${RUN_ID}.log"
else
  LOGFILE="$(pick_newest_log "$LABEL_VALUE")"
  if [[ -n "$LOGFILE" ]]; then
    RUN_ID="$(sed -n 's/.*-media-tools-\([0-9]\{12\}\)\.log/\1/p' <<<"$(basename "$LOGFILE")" | head -n 1)"
  else
    RUN_ID="$(run_id_now)"
    LOGFILE="/logs/${LABEL_VALUE}-media-tools-${RUN_ID}.log"
  fi
fi

START_TS="$(timestamp_now)"
if [[ "$KIND" == "tv" ]]; then
  MSG="$(printf "Show: %s | run_id=%s" "$SHOW_NAME" "$RUN_ID")"
else
  MSG="$(printf "Kind: %s | run_id=%s\nTarget: %s" "$KIND" "$RUN_ID" "$TARGET_PATH")"
fi
command -v notify_discord >/dev/null 2>&1 && \
  notify_discord "🔉 Step 2 of 3: Normalize Audio started" "$MSG" || true

log_line "$LOGFILE" "${START_TS}  normalize_audio START"
log_line "$LOGFILE" "  run_id=${RUN_ID}"
log_line "$LOGFILE" "  input=${TARGET_PATH}"
log_line "$LOGFILE" "  kind=${KIND}"
log_line "$LOGFILE" "  settings: I=${TARGET_I} TP=${TRUE_PEAK} LRA=${LRA} stereo_track=${STEREO_TRACK} one_pass=${ONE_PASS} dry_run=${DRY_RUN} force=${FORCE}"
log_line "$LOGFILE" "  files:"

# Find *.norm.mp4 files
find_err="$(mktemp)"
FILES=()

if [[ "$TARGET_MODE" == "file" ]]; then
  FILES=("$TARGET_PATH")
else
  mapfile -d '' FILES < <(
    find "$TARGET_PATH" -type f -name "*.norm.mp4" ! -name "._*" ! -name ".DS_Store" -print0 2>"$find_err" | sort -z || true
  )
fi

# Log find errors
if [[ -s "$find_err" ]]; then
  log_line "$LOGFILE" "  WARN: find had errors:"
  while IFS= read -r line; do
    log_line "$LOGFILE" "    $line"
  done < "$find_err"
fi
rm -f "$find_err"

if [[ ${#FILES[@]} -eq 0 ]]; then
  log_line "$LOGFILE" "    (none found)"
  log_line "$LOGFILE" "normalize_audio END status=OK"
  if [[ "$KIND" == "tv" ]]; then
    MSG="$(printf "Show: %s | run_id=%s\nNo .norm.mp4 files found, nothing to do." "$SHOW_NAME" "$RUN_ID")"
  else
    MSG="$(printf "Kind: %s | run_id=%s\nNo .norm.mp4 files found, nothing to do.\nTarget: %s" "$KIND" "$RUN_ID" "$TARGET_PATH")"
  fi
  command -v notify_discord >/dev/null 2>&1 && \
    notify_discord "⚠️ Step 2 of 3: Normalize Audio finished" "$MSG" "$LOGFILE" || true
  exit 0
fi

FAILS=0
CREATED=0
SKIPPED=0
COUNT=${#FILES[@]}
CURR=0

for in_file in "${FILES[@]}"; do
  CURR=$((CURR+1))

  # rel path for logging
  if [[ "$TARGET_MODE" == "file" ]]; then
    rel="$(basename "$in_file")"
  else
    rel="${in_file#$REL_BASE/}"
  fi

  log_line "$LOGFILE" "    $rel"

  out_file="${in_file%.norm.mp4}.mp4"
  tmp_file="${out_file%.mp4}.mp4.tmp.mp4"

  if [[ -f "$out_file" && "$FORCE" != "1" ]]; then
    log_line "$LOGFILE" "    SKIPPED ($CURR of $COUNT): output exists -> ${out_file#$REL_BASE/}"
    SKIPPED=$((SKIPPED+1))
    continue
  fi

  if [[ "$DRY_RUN" == "1" ]]; then
    log_line "$LOGFILE" "    DRYRUN ($CURR of $COUNT): $rel -> ${out_file#$REL_BASE/}"
    continue
  fi

  ch="$(ffprobe_channels "$in_file")"
  if [[ -z "$ch" ]]; then
    log_line "$LOGFILE" "    FAILED (no audio info): $rel"
    FAILS=$((FAILS+1))
    continue
  fi

  # Build ffmpeg command(s)
  if [[ "$ch" -ge 6 && "$STEREO_TRACK" == "on" ]]; then
    # 5.1 + stereo track
    if [[ "$ONE_PASS" == "1" ]]; then
      # One-pass: apply directly
      if ffmpeg -hide_banner -y -i "$in_file" \
          -map 0:v:0 -map 0:a:0 -map 0:a:0 \
          -map 0:s? \
          -c:v copy \
          -c:a:0 aac -b:a:0 512k \
          -c:a:1 aac -b:a:1 256k \
          -c:s copy \
          -filter:a:0 "loudnorm=I=${TARGET_I}:TP=${TRUE_PEAK}:LRA=${LRA}" \
          -filter:a:1 "pan=stereo|c0=0.5*FL+0.707*FC+0.5*BL|c1=0.5*FR+0.707*FC+0.5*BR,loudnorm=I=${TARGET_I}:TP=${TRUE_PEAK}:LRA=${LRA}" \
          -movflags +faststart \
          "$tmp_file"; then
        mv -f "$tmp_file" "$out_file"
        rm -f "$in_file"
        log_line "$LOGFILE" "    NORMALIZED(1pass) + DELETED .norm ($CURR of $COUNT): $rel -> ${out_file#$REL_BASE/}"
        MSG="$(printf "NORMALIZED(1pass): %s\nDELETED: %s" "${out_file#$REL_BASE/}" "$rel")"
        command -v notify_discord >/dev/null 2>&1 && \
          notify_discord "☑️ ffmpeg: Normalized audio ($CURR of $COUNT)" "$MSG" || true
        CREATED=$((CREATED+1))
      else
        rm -f "$tmp_file" || true
        log_line "$LOGFILE" "    FAILED: $rel"
        MSG="$(printf "%s: %s | run_id=%s\nFailed file: %s" "$TARGET_LABEL" "$LABEL_VALUE" "$RUN_ID" "$rel")"
        command -v notify_discord >/dev/null 2>&1 && \
          notify_discord "❌ ffmpeg: Failed to normalize audio" "$MSG" "$LOGFILE" || true
        FAILS=$((FAILS+1))
      fi
    else
      # Two-pass: measure 5.1 and measure downmix separately
      meas_51="$(measure_loudnorm "$in_file" "")"
      meas_st="$(measure_loudnorm "$in_file" "pan=stereo|c0=0.5*FL+0.707*FC+0.5*BL|c1=0.5*FR+0.707*FC+0.5*BR,")"

      f51="$(apply_two_pass_filter "$meas_51")"
      fst="$(apply_two_pass_filter "$meas_st")"

      # Log measured summaries (concise)
      log_line "$LOGFILE" "    measure: $rel"
      log_line "$LOGFILE" "      5.1 input_i=$(jq -r '.input_i' <<<"$meas_51") input_tp=$(jq -r '.input_tp' <<<"$meas_51") input_lra=$(jq -r '.input_lra' <<<"$meas_51") offset=$(jq -r '.target_offset' <<<"$meas_51")"
      log_line "$LOGFILE" "      st  input_i=$(jq -r '.input_i' <<<"$meas_st") input_tp=$(jq -r '.input_tp' <<<"$meas_st") input_lra=$(jq -r '.input_lra' <<<"$meas_st") offset=$(jq -r '.target_offset' <<<"$meas_st")"

      if ffmpeg -hide_banner -y -i "$in_file" \
          -map 0:v:0 -map 0:a:0 -map 0:a:0 \
          -map 0:s? \
          -c:v copy \
          -c:a:0 aac -b:a:0 512k \
          -c:a:1 aac -b:a:1 256k \
          -c:s copy \
          -filter:a:0 "$f51" \
          -filter:a:1 "pan=stereo|c0=0.5*FL+0.707*FC+0.5*BL|c1=0.5*FR+0.707*FC+0.5*BR,$fst" \
          -movflags +faststart \
          "$tmp_file"; then
        mv -f "$tmp_file" "$out_file"
        rm -f "$in_file"
        log_line "$LOGFILE" "    NORMALIZED(2pass) + DELETED .norm ($CURR of $COUNT): $rel -> ${out_file#$REL_BASE/}"
        MSG="$(printf "NORMALIZED(2pass): %s\nDELETED: %s" "${out_file#$REL_BASE/}" "$rel")"
        command -v notify_discord >/dev/null 2>&1 && \
          notify_discord "☑️ ffmpeg: Normalized audio ($CURR of $COUNT)" "$MSG" || true
        CREATED=$((CREATED+1))
      else
        rm -f "$tmp_file" || true
        log_line "$LOGFILE" "    FAILED: $rel"
        MSG="$(printf "%s: %s | run_id=%s\nFailed file: %s" "$TARGET_LABEL" "$LABEL_VALUE" "$RUN_ID" "$rel")"
        command -v notify_discord >/dev/null 2>&1 && \
          notify_discord "❌ ffmpeg: Failed to normalize audio" "$MSG" "$LOGFILE" || true
        FAILS=$((FAILS+1))
      fi
    fi
  else
    # Stereo-only output
    if [[ "$ONE_PASS" == "1" ]]; then
      if ffmpeg -hide_banner -y -i "$in_file" \
          -map 0:v:0 -map 0:a:0 \
          -map 0:s? \
          -c:v copy \
          -c:a aac -b:a 256k \
          -c:s copy \
          -filter:a "loudnorm=I=${TARGET_I}:TP=${TRUE_PEAK}:LRA=${LRA}" \
          -movflags +faststart \
          "$tmp_file"; then
        mv -f "$tmp_file" "$out_file"
        rm -f "$in_file"
        log_line "$LOGFILE" "    NORMALIZED(1pass) + DELETED .norm ($CURR of $COUNT): $rel -> ${out_file#$REL_BASE/}"
        MSG="$(printf "NORMALIZED(1pass): %s\nDELETED: %s" "${out_file#$REL_BASE/}" "$rel")"
        command -v notify_discord >/dev/null 2>&1 && \
          notify_discord "☑️ ffmpeg: Normalized audio ($CURR of $COUNT)" "$MSG" || true
        CREATED=$((CREATED+1))
      else
        rm -f "$tmp_file" || true
        log_line "$LOGFILE" "    FAILED: $rel"
        MSG="$(printf "%s: %s | run_id=%s\nFailed file: %s" "$TARGET_LABEL" "$LABEL_VALUE" "$RUN_ID" "$rel")"
        command -v notify_discord >/dev/null 2>&1 && \
          notify_discord "❌ ffmpeg: Failed to normalize audio" "$MSG" "$LOGFILE" || true
        FAILS=$((FAILS+1))
      fi
    else
      meas="$(measure_loudnorm "$in_file" "")"
      f="$(apply_two_pass_filter "$meas")"
      log_line "$LOGFILE" "      measure: $rel input_i=$(jq -r '.input_i' <<<"$meas") input_tp=$(jq -r '.input_tp' <<<"$meas") input_lra=$(jq -r '.input_lra' <<<"$meas") offset=$(jq -r '.target_offset' <<<"$meas")"

      if ffmpeg -hide_banner -y -i "$in_file" \
          -map 0:v:0 -map 0:a:0 \
          -map 0:s? \
          -c:v copy \
          -c:a aac -b:a 256k \
          -c:s copy \
          -filter:a "$f" \
          -movflags +faststart \
          "$tmp_file"; then
        mv -f "$tmp_file" "$out_file"
        rm -f "$in_file"
        log_line "$LOGFILE" "    NORMALIZED(2pass) + DELETED .norm ($CURR of $COUNT): $rel -> ${out_file#$REL_BASE/}"
        MSG="$(printf "NORMALIZED(2pass): %s\nDELETED: %s" "${out_file#$REL_BASE/}" "$rel")"
        command -v notify_discord >/dev/null 2>&1 && \
          notify_discord "☑️ ffmpeg: Normalized audio ($CURR of $COUNT)" "$MSG" || true
        CREATED=$((CREATED+1))
      else
        rm -f "$tmp_file" || true
        log_line "$LOGFILE" "    FAILED: $rel"
        MSG="$(printf "%s: %s | run_id=%s\nFailed file: %s" "$TARGET_LABEL" "$LABEL_VALUE" "$RUN_ID" "$rel")"
        command -v notify_discord >/dev/null 2>&1 && \
          notify_discord "❌ ffmpeg: Failed to normalize audio" "$MSG" "$LOGFILE" || true
        FAILS=$((FAILS+1))
      fi
    fi
  fi
done

END_TS="$(timestamp_now)"
STATUS="OK"
if [[ "$FAILS" -gt 0 ]]; then STATUS="PARTIAL"; fi
log_line "$LOGFILE" "${END_TS}  normalize_audio END status=${STATUS} normalized=${CREATED} skipped=${SKIPPED} failed=${FAILS}"

if [[ "$KIND" == "tv" ]]; then
  MSG="$(printf "Show: %s | run_id=%s | normalized=%s skipped=%s failed=%s" "$SHOW_NAME" "$RUN_ID" "$CREATED" "$SKIPPED" "$FAILS")"
else
  MSG="$(printf "Kind: %s | run_id=%s | normalized=%s skipped=%s failed=%s" "$KIND" "$RUN_ID" "$CREATED" "$SKIPPED" "$FAILS")"
fi
command -v notify_discord >/dev/null 2>&1 && \
    notify_discord "✅ Step 2 of 3: Normalize Audio finished" "$MSG" "$LOGFILE" || true

if [[ "$FAILS" -gt 0 ]]; then
  exit 3
fi

exit 0